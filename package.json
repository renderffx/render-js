{
  "name": "render.js",
  "version": "0.1.0",
  "private": true,
  "description": "Fastest React Server Components framework",
  "workspaces": [
    "packages/*",
    "demo-app"
  ],
  "scripts": {
    "dev": "bun run --filter @renderjs/cli dev",
    "build": "bun run --filter @renderjs/core build && bun run --filter @renderjs/cli build",
    "test": "bun run --filter @renderjs/core test",
    "typecheck": "bun run --filter @renderjs/core typecheck",
    "bench": "bun run --filter @renderjs/core bench"
  },
  "keywords": [
    "react",
    "rsc",
    "server-components",
    "framework",
    "bun",
    "fast"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-rsc": "^0.5.21",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^6.4.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.7.0"
  }
}
