{
  "name": "@renderjs/core",
  "version": "1.0.0",
  "type": "module",
  "description": "Production-ready React Server Components framework powered by @vitejs/plugin-rsc",
  "keywords": [
    "react",
    "rsc",
    "react-server-components",
    "framework",
    "vercel",
    "edge",
    "serverless"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./router": {
      "import": "./dist/router.js",
      "types": "./dist/router.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./minimal/client": {
      "import": "./dist/minimal/client.js",
      "types": "./dist/minimal/client.d.ts"
    },
    "./vercel-native": {
      "import": "./dist/vercel-native.js",
      "types": "./dist/vercel-native.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench",
    "e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vercel/og": "^0.6.3",
    "@vitejs/plugin-rsc": "^0.5.21",
    "magic-string": "^0.30.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-server-dom-webpack": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "directories": {
    "test": "tests"
  },
  "author": "@render.js",
  "license": "MIT",
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/renderjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/renderjs/renderjs"
  }
}
